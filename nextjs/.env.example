# LLM Provider Configuration
# Choose one: "google" | "anthropic" | "openai" | "groq"
LLM_PROVIDER=google

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=

# Groq
GROQ_API_KEY=
GROQ_MODEL=

# MCP Server URLs
MODEL_INTERPRETATION_URL=http://localhost:3001
DATABASE_QUERY_URL=http://localhost:3002

# Shared bearer token sent on every request to the MCP servers.
# Must match MCP_API_TOKEN configured in mcp-servers/.env.
# Leave blank for local dev (MCP servers will allow unauthenticated requests
# and log a warning); REQUIRED in production.
MCP_API_TOKEN=

# Database (metadata store: projects, sessions, users — needs read/write).
# NOTE: this is NOT the target query database. The per-project target-DB
# credentials are entered in the project-setup UI and should use a SELECT-only
# role (chatbot_ro) for NFR-01 — see mcp-servers/scripts/create-readonly-role.sql.
DATABASE_URL=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Secret used to encrypt per-user LLM API keys at rest (agent_configs.api_key).
# Required. Generate one with: openssl rand -base64 48
# Rotating this value will invalidate all stored per-user API keys; users will
# need to re-enter them.
API_KEY_ENCRYPTION_SECRET=
