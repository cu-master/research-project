# LangChain Server Configuration

# Server port (default: 4000)
PORT=

# Max request body size (default: 10mb)
REQUEST_SIZE_LIMIT=

# LLM Provider Configuration
# Choose one: "google" | "anthropic" | "openai"
LLM_PROVIDER=google

# Google Gemini
# Tier 1
GOOGLE_API_KEY=
# Free Tier
GOOGLE_MODEL=
GOOGLE_MODEL_PRO=

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=

# DB
DATABASE_URL=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=





