{
  "name": "ai-chatbot-frontend",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm test && npm run test:integration",
    "benchmark:ai-accuracy": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/run-ai-accuracy-benchmark.ts",
    "benchmark:ai-accuracy:report": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/run-ai-accuracy-benchmark.ts --strict",
    "benchmark:verify-ground-truth": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify-benchmark-ground-truth.ts",
    "benchmark:verify-ground-truth:strict": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/verify-benchmark-ground-truth.ts --strict"
  },
  "dependencies": {
    "@heroicons/react": "2.1.5",
    "@langchain/anthropic": "^1.3.23",
    "@langchain/core": "^1.1.32",
    "@langchain/google-genai": "^2.1.25",
    "@langchain/openai": "^1.2.13",
    "@prisma/client": "^6.19.2",
    "@types/n3": "^1.26.1",
    "bcryptjs": "^3.0.3",
    "clsx": "2.1.1",
    "langchain": "^1.2.32",
    "n3": "^2.0.1",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/express": "^5.0.6",
    "@types/node": "22.7.5",
    "@types/pg": "^8.16.0",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "10.4.20",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "express": "^5.2.1",
    "postcss": "8.4.47",
    "prisma": "^6.19.2",
    "tailwindcss": "3.4.13",
    "typescript": "5.6.3",
    "vitest": "^3.2.4"
  }
}
