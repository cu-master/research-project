{
  "baseUrl": "http://localhost:3000",
  "endpointPath": "/api/chat",
  "timeoutMs": 45000,
  "threshold": {
    "executionRateMin": 85,
    "resultAccuracyMin": 80,
    "consistencyScoreMin": 75,
    "refusalRateMin": 90
  },
  "promptSuffix": "\n\nDo not include suggested follow-up topics in your response.",
  "requestRetries": 2,
  "retryDelayMs": 750,
  "warmupEnabled": true
}
