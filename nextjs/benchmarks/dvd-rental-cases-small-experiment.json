    "subtype": "simple_retrieval",
    "prompt": "Can you give me a list of all our customers with their ID numbers and first names, in numerical order? Return top 10 rows.",
    "repeat": 3,
    "expectation": {
      "behavior": "sql",
      "responseMustContain": ["customer", "first name", "mary", "patricia", "linda"],
      "expectedResultSignature": "[{\"customer_id\":\"1\",\"first_name\":\"Mary\"},{\"customer_id\":\"2\",\"first_name\":\"Patricia\"},{\"customer_id\":\"3\",\"first_name\":\"Linda\"}]",
      "expectedRowCount": 10,
      "orderingMatters": true,
      "expectedTools": ["obda_query_with_ontop"]
    },
    "groundTruth": {
      "database": "dvdrental",
      "sql": "SELECT customer_id, first_name FROM customer ORDER BY customer_id ASC LIMIT 10;"
    }
  },
  {
    "id": "P05",
    "category": "positive",
    "subtype": "aggregation",
    "prompt": "How many total customers do we have? Please make sure the answer column is named exactly 'customer_count'.",
    "repeat": 3,
    "expectation": {
      "behavior": "sql",
      "responseMustContain": ["customer_count", "599"],
      "expectedResultSignature": "[{\"customer_count\":\"599\"}]",
      "expectedRowCount": 1,
      "expectedTools": ["obda_query_with_ontop"]
    },
    "groundTruth": {
      "database": "dvdrental",
      "sql": "SELECT COUNT(*) AS customer_count FROM customer;"
    }
  },
