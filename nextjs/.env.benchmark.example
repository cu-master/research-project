# Optional benchmark overrides for scripts/run-ai-accuracy-benchmark.ts
# Copy to .env.benchmark (gitignored). Loaded after .env; shell env wins.

# Base URL for the Next.js app when calling /api/chat (falls back to benchmarks/config.json)
BENCHMARK_BASE_URL=

# Session cookie for authenticated /api/chat calls (required unless you pass --cookie)
BENCHMARK_AUTH_COOKIE=

# Optional: LLM sampling / reproducibility (also see benchmarks/config.json)
BENCHMARK_MODEL_TEMPERATURE=
# Alias used by some setups:
# LLM_TEMPERATURE=

BENCHMARK_MODEL_SEED=

# Appended to benchmark warmup and case prompts (empty uses script default)
BENCHMARK_PROMPT_SUFFIX=
