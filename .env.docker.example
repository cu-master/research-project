# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose environment for the full stack.
# Copy to .env (which is gitignored), then fill in secrets and your LLM key:
#   cp .env.docker.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets (REQUIRED) ───────────────────────────────────────────────────────
# Shared bearer token between the Next.js app and both MCP servers — must match.
#   openssl rand -base64 32
MCP_API_TOKEN=

# NextAuth session secret.   openssl rand -base64 32
NEXTAUTH_SECRET=

# Encrypts per-user LLM API keys at rest. Rotating it invalidates stored keys.
#   openssl rand -base64 48
API_KEY_ENCRYPTION_SECRET=

# ── LLM provider (pick one provider + set its API key) ───────────────────────
# LLM_PROVIDER: google | anthropic | openai | groq
LLM_PROVIDER=google
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── App URLs ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
MCP_CORS_ORIGINS=http://localhost:3000

# ── Application / metadata database (app-db) ─────────────────────────────────
APP_DB_USER=chatbot
APP_DB_PASSWORD=chatbot
APP_DB_NAME=chatbot_db

# ── Sample target database (target-db) ───────────────────────────────────────
TARGET_DB_ADMIN_USER=postgres
TARGET_DB_ADMIN_PASSWORD=postgres
TARGET_DB_NAME=dvdrental
# Password for the read-only role the chatbot connects as. Enter this in the
# project-setup UI alongside host=target-db, port=5432, user=chatbot_ro.
TARGET_DB_RO_PASSWORD=ro_password

# ── MCP server tuning (optional; defaults shown) ─────────────────────────────
MCP_REQUEST_SIZE_LIMIT=10mb
MCP_RATE_LIMIT_MAX=60
MCP_RATE_LIMIT_WINDOW_MS=60000
