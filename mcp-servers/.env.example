# Server configuration
# Server Ports
DB_MCP_SERVER_PORT=3002

# Max request body size (default: 10mb)
REQUEST_SIZE_LIMIT=10mb

# Shared bearer token required on /tools/* and /mcp/* endpoints.
# Leave blank for local dev (a warning is logged); REQUIRED in production.
# Generate with: openssl rand -base64 32
# The Next.js app must set the same value as MCP_API_TOKEN.
MCP_API_TOKEN=

# Per-IP rate limit (token bucket). Defaults: 60 req / 60_000ms.
MCP_RATE_LIMIT_MAX=60
MCP_RATE_LIMIT_WINDOW_MS=60000

# Comma-separated CORS allow-list (e.g. http://localhost:3000,https://app.example.com).
# Empty = no cross-origin browser access (curl/server-to-server still works).
MCP_CORS_ORIGINS=http://localhost:3000

# LLM Provider Configuration
# Choose one: "google" | "anthropic" | "openai" | "groq"
LLM_PROVIDER=google

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_MODEL_PRO=gemini-2.5-pro

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile 


# Ontop / OBDA Configuration
ONTOP_SPARQL_URL=http://localhost:8080/sparql
# ONTOP_INPUT_DIR=../ontop/input
# PROJECT_ROOT=../
