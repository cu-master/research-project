# Server configuration
# Server Ports
DB_MCP_SERVER_PORT=3002

# Max request body size (default: 10mb)
REQUEST_SIZE_LIMIT=10mb

# LLM Provider Configuration
# Choose one: "google" | "anthropic" | "openai" | "groq"
LLM_PROVIDER=google

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_MODEL_PRO=gemini-2.5-pro

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile 


# Ontop / OBDA Configuration
ONTOP_SPARQL_URL=http://localhost:8080/sparql
# ONTOP_INPUT_DIR=../ontop/input
# PROJECT_ROOT=../

# Supabase Configuration (required)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Database 1
DB_1_TYPE=postgresql
DB_1_ID=local_pg
DB_1_NAME=Local PostgreSQL
DB_1_HOST=localhost
DB_1_PORT=5432
DB_1_DATABASE=mydb
DB_1_USER=postgres
DB_1_PASSWORD=your_password_here
DB_1_SSL=false

# Database 2
DB_2_TYPE=supabase
DB_2_ID=prod_supabase
DB_2_NAME=Production Supabase
DB_2_URL=your_supabase_database_url_here
DB_2_SERVICE_KEY=your_supabase_service_key_here