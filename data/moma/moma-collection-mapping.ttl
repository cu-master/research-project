@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix moma: <https://moma.org/ontology/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# =============================================================================
# TriplesMap: artists → moma:Artist
# =============================================================================

<#ArtistMap>
    a rr:TriplesMap ;

    rr:logicalTable [ rr:tableName "artists" ] ;

    rr:subjectMap [
        rr:template "https://moma.org/resource/artist/{constituent_id}" ;
        rr:class moma:Artist
    ] ;

    # moma:constituentId — unique numeric identifier for the artist
    rr:predicateObjectMap [
        rr:predicate moma:constituentId ;
        rr:objectMap [
            rr:column "constituent_id" ;
            rr:datatype xsd:integer
        ]
    ] ;

    # moma:artistName — display name of the artist
    rr:predicateObjectMap [
        rr:predicate moma:artistName ;
        rr:objectMap [
            rr:column "name" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:biography — biographical text
    rr:predicateObjectMap [
        rr:predicate moma:biography ;
        rr:objectMap [
            rr:column "bio" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:nationality — artist's nationality
    rr:predicateObjectMap [
        rr:predicate moma:nationality ;
        rr:objectMap [
            rr:column "nationality" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:gender — artist's gender
    rr:predicateObjectMap [
        rr:predicate moma:gender ;
        rr:objectMap [
            rr:column "gender" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:birthYear — year of birth; stored as integer in DB, mapped to xsd:gYear
    rr:predicateObjectMap [
        rr:predicate moma:birthYear ;
        rr:objectMap [
            rr:column "birth_year" ;
            rr:datatype xsd:gYear
        ]
    ] ;

    # moma:deathYear — year of death; stored as integer in DB, mapped to xsd:gYear
    rr:predicateObjectMap [
        rr:predicate moma:deathYear ;
        rr:objectMap [
            rr:column "death_year" ;
            rr:datatype xsd:gYear
        ]
    ] ;

    # moma:wikiQid — Wikidata entity identifier
    rr:predicateObjectMap [
        rr:predicate moma:wikiQid ;
        rr:objectMap [
            rr:column "wiki_qid" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:ulanId — Getty ULAN identifier
    rr:predicateObjectMap [
        rr:predicate moma:ulanId ;
        rr:objectMap [
            rr:column "ulan_id" ;
            rr:datatype xsd:string
        ]
    ] .


# =============================================================================
# TriplesMap: artworks → moma:Artwork
#
# NOTE: The artworks table has no explicit primary key declared in the schema.
#       object_id is used as the de-facto unique identifier for IRI generation
#       because it corresponds to moma:objectId and is the standard MoMA object
#       identifier. The mapping uses a SQL view / rr:sqlQuery to filter rows
#       where object_id IS NOT NULL so that IRI generation is safe.
# =============================================================================

<#ArtworkMap>
    a rr:TriplesMap ;

    rr:logicalTable [
        rr:sqlQuery """
            SELECT
                object_id,
                title,
                artist,
                constituent_id,
                artist_bio,
                nationality,
                begin_date,
                end_date,
                gender,
                date,
                medium,
                dimensions,
                credit_line,
                accession_number,
                classification,
                department,
                date_acquired,
                cataloged,
                url,
                image_url,
                on_view,
                circumference_cm,
                depth_cm,
                diameter_cm,
                height_cm,
                length_cm,
                weight_kg,
                width_cm,
                seat_height_cm,
                duration_sec
            FROM artworks
            WHERE object_id IS NOT NULL
        """
    ] ;

    rr:subjectMap [
        rr:template "https://moma.org/resource/artwork/{object_id}" ;
        rr:class moma:Artwork
    ] ;

    # moma:objectId — unique numeric identifier
    rr:predicateObjectMap [
        rr:predicate moma:objectId ;
        rr:objectMap [
            rr:column "object_id" ;
            rr:datatype xsd:integer
        ]
    ] ;

    # moma:title — title of the artwork
    rr:predicateObjectMap [
        rr:predicate moma:title ;
        rr:objectMap [
            rr:column "title" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:medium — materials and techniques
    rr:predicateObjectMap [
        rr:predicate moma:medium ;
        rr:objectMap [
            rr:column "medium" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:dimensions — human-readable dimensions description
    rr:predicateObjectMap [
        rr:predicate moma:dimensions ;
        rr:objectMap [
            rr:column "dimensions" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:creditLine — formal attribution text
    rr:predicateObjectMap [
        rr:predicate moma:creditLine ;
        rr:objectMap [
            rr:column "credit_line" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:accessionNumber — museum registration code
    rr:predicateObjectMap [
        rr:predicate moma:accessionNumber ;
        rr:objectMap [
            rr:column "accession_number" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:classification — broad category (Painting, Photograph, etc.)
    rr:predicateObjectMap [
        rr:predicate moma:classification ;
        rr:objectMap [
            rr:column "classification" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:artworkDate — creation date as free-text string (column: date)
    rr:predicateObjectMap [
        rr:predicate moma:artworkDate ;
        rr:objectMap [
            rr:column "date" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:momaUrl — URL of the artwork's page on the MoMA website
    rr:predicateObjectMap [
        rr:predicate moma:momaUrl ;
        rr:objectMap [
            rr:column "url" ;
            rr:datatype xsd:anyURI
        ]
    ] ;

    # moma:onView — whether the artwork is currently on public display.
    # NOTE: Stored as text in the DB (e.g. "Y"/"N" or "true"/"false").
    #       Mapped to xsd:string here; downstream processing may cast to xsd:boolean.
    rr:predicateObjectMap [
        rr:predicate moma:onView ;
        rr:objectMap [
            rr:column "on_view" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:heightCm — height in centimetres (stored as text in DB)
    rr:predicateObjectMap [
        rr:predicate moma:heightCm ;
        rr:objectMap [
            rr:column "height_cm" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:widthCm — width in centimetres (stored as text in DB)
    rr:predicateObjectMap [
        rr:predicate moma:widthCm ;
        rr:objectMap [
            rr:column "width_cm" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:depthCm — depth in centimetres (stored as text in DB)
    rr:predicateObjectMap [
        rr:predicate moma:depthCm ;
        rr:objectMap [
            rr:column "depth_cm" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:weightKg — weight in kilograms (stored as text in DB)
    rr:predicateObjectMap [
        rr:predicate moma:weightKg ;
        rr:objectMap [
            rr:column "weight_kg" ;
            rr:datatype xsd:string
        ]
    ] ;

    # moma:durationSec — running time in seconds for time-based media (stored as text in DB)
    rr:predicateObjectMap [
        rr:predicate moma:durationSec ;
        rr:objectMap [
            rr:column "duration_sec" ;
            rr:datatype xsd:string
        ]
    ] ;

    # dcterms:description reused for the department text column.
    # NOTE: The artworks table stores department as a plain text string rather
    #       than a foreign key. It is mapped as a literal here. A full
    #       moma:belongsToDepartment object-property link would require a
    #       separate departments table with a proper FK relationship.
    rr:predicateObjectMap [
        rr:predicate moma:classification ;
        rr:objectMap [
            rr:column "department" ;
            rr:datatype xsd:string
        ]
    ] ;

    # NOTE: The artworks.department column is also surfaced via dcterms:subject
    #       as a department label literal for discoverability.
    rr:predicateObjectMap [
        rr:predicate dcterms:subject ;
        rr:objectMap [
            rr:column "department" ;
            rr:datatype xsd:string
        ]
    ] ;

    # date_acquired — stored as text; mapped to dcterms:dateSubmitted as a
    # literal because no structured Acquisition FK exists in this schema.
    # NOTE: When an acquisitions table with a proper FK is available, replace
    #       this with a moma:acquiredArtwork RefObjectMap.
    rr:predicateObjectMap [
        rr:predicate dcterms:dateSubmitted ;
        rr:objectMap [
            rr:column "date_acquired" ;
            rr:datatype xsd:string
        ]
    ] ;

    # cataloged — free-text cataloguing status; no direct ontology property.
    # Mapped to dcterms:description with a note.
    # NOTE: Assumption — 'cataloged' records whether the item has been fully
    #       catalogued; mapped to dcterms:description as a fallback literal.
    rr:predicateObjectMap [
        rr:predicate dcterms:description ;
        rr:objectMap [
            rr:column "cataloged" ;
            rr:datatype xsd:string
        ]
    ] ;

    # image_url — URL of a representative image; mapped to moma:mediaUrl as a
    # literal shortcut. A full moma:MediaAsset node would require a separate
    # media_assets table.
    # NOTE: Assumption — image_url is treated as a primary media URL literal
    #       pending a dedicated MediaAsset table.
    rr:predicateObjectMap [
        rr:predicate moma:mediaUrl ;
        rr:objectMap [
            rr:column "image_url" ;
            rr:datatype xsd:anyURI
        ]
    ] ;

    # artist (denormalised text) — stored as plain text artist name on the
    # artwork row. Mapped to dcterms:creator as a literal fallback.
    # NOTE: The proper semantic link is via moma:ArtworkCredit / moma:hasCredit,
    #       but that requires a separate artwork_credits join table. The raw
    #       text value is preserved here for completeness.
    rr:predicateObjectMap [
        rr:predicate dcterms:creator ;
        rr:objectMap [
            rr:column "artist" ;
            rr:datatype xsd:string
        ]
    ] ;

    # artist_bio — denormalised biography text copied onto the artwork row.
    # NOTE: Assumption — redundant with artists.bio; kept as a literal for
    #       provenance of the denormalised value.
    rr:predicateObjectMap [
        rr:predicate dcterms:description ;
        rr:objectMap [
            rr:column "artist_bio" ;
            rr:datatype xsd:string
        ]
    ] ;

    # nationality — denormalised nationality text on the artwork row.
    # NOTE: Redundant with artists.nationality; preserved as a literal.
    rr:predicateObjectMap [
        rr:predicate moma:nationality ;
        rr:objectMap [
            rr:column "nationality" ;
            rr:datatype xsd:string
        ]
    ] ;

    # gender — denormalised gender text on the artwork row.
    # NOTE: Redundant with artists.gender; preserved as a literal.
    rr:predicateObjectMap [
        rr:predicate moma:gender ;
        rr:objectMap [
            rr:column "gender" ;
            rr:datatype xsd:string
        ]
    ] ;

    # begin_date — denormalised artist birth year text on the artwork row.
    # NOTE: Corresponds to artists.birth_year; stored as text here.
    rr:predicateObjectMap [
        rr:predicate moma:birthYear ;
        rr:objectMap [
            rr:column "begin_date" ;
            rr:datatype xsd:string
        ]
    ] ;

    # end_date — denormalised artist death year text on the artwork row.
    # NOTE: Corresponds to artists.death_year; stored as text here.
    rr:predicateObjectMap [
        rr:predicate moma:deathYear ;
        rr:objectMap [
            rr:column "end_date" ;
            rr:datatype xsd:string
        ]
    ] ;

    # circumference_cm — no direct ontology property defined.
    # NOTE: Assumption — mapped to a custom moma:circumferenceCm literal
    #       as a physical dimension attribute not explicitly modelled in the
    #       ontology but consistent with the dimension properties pattern.
    rr:predicateObjectMap [
        rr:predicate moma:circumferenceCm ;
        rr:objectMap [
            rr:column "circumference_cm" ;
            rr:datatype xsd:string
        ]
    ] ;

    # diameter_cm — no direct ontology property defined.
    # NOTE: Assumption — mapped to moma:diameterCm as a physical dimension
    #       attribute consistent with the ontology's dimension properties pattern.
    rr:predicateObjectMap [
        rr:predicate moma:diameterCm ;
        rr:objectMap [
            rr:column "diameter_cm" ;
            rr:datatype xsd:string
        ]
    ] ;

    # length_cm — no direct ontology property defined.
    # NOTE: Assumption — mapped to moma:lengthCm as a physical dimension
    #       attribute consistent with the ontology's dimension properties pattern.
    rr:predicateObjectMap [
        rr:predicate moma:lengthCm ;
        rr:objectMap [
            rr:column "length_cm" ;
            rr:datatype xsd:string
        ]
    ] ;

    # seat_height_cm — no direct ontology property defined.
    # NOTE: Assumption — mapped to moma:seatHeightCm as a specialised physical
    #       dimension relevant to furniture/design objects in the collection.
    rr:predicateObjectMap [
        rr:predicate moma:seatHeightCm ;
        rr:objectMap [
            rr:column "seat_height_cm" ;
            rr:datatype xsd:string
        ]
    ] .


# =============================================================================
# TriplesMap: artworks → moma:ArtworkCredit  (inline credit from denormalised
#             constituent_id column on the artworks table)
#
# NOTE: The physical schema does not contain a dedicated artwork_credits table.
#       The artworks table carries a constituent_id text column that represents
#       a (potentially comma-separated) list of artist identifiers. This map
#       creates one ArtworkCredit node per artwork row using the artwork's
#       object_id as a surrogate key, linking the artwork to its primary artist
#       where constituent_id is a single parseable integer. For multi-valued
#       constituent_id strings a proper ETL normalisation step is recommended.
# =============================================================================

<#ArtworkCreditMap>
    a rr:TriplesMap ;

    rr:logicalTable [
        rr:sqlQuery """
            SELECT
                object_id,
                constituent_id
            FROM artworks
            WHERE object_id IS NOT NULL
              AND constituent_id IS NOT NULL
              AND constituent_id NOT LIKE '%,%'
              AND constituent_id ~ '^[0-9]+$'
        """
    ] ;

    rr:subjectMap [
        rr:template "https://moma.org/resource/artworkcredit/{object_id}" ;
        rr:class moma:ArtworkCredit
    ] ;

    # moma:creditedArtwork — links this credit to the artwork
    rr:predicateObjectMap [
        rr:predicate moma:creditedArtwork ;
        rr:objectMap [
            rr:template "https://moma.org/resource/artwork/{object_id}"
        ]
    ] ;

    # moma:creditedArtist — links this credit to the artist via constituent_id
    rr:predicateObjectMap [
        rr:predicate moma:creditedArtist ;
        rr:objectMap [
            rr:template "https://moma.org/resource/artist/{constituent_id}"
        ]
    ] .


# =============================================================================
# TriplesMap: artworks → moma:hasCredit (inverse link from Artwork to Credit)
#
# NOTE: This map adds the moma:hasCredit triple on the Artwork subject,
#       pointing to the ArtworkCredit node created above, satisfying the
#       inverse-of relationship declared in the ontology.
# =============================================================================

<#ArtworkHasCreditMap>
    a rr:TriplesMap ;

    rr:logicalTable [
        rr:sqlQuery """
            SELECT
                object_id,
                constituent_id
            FROM artworks
            WHERE object_id IS NOT NULL
              AND constituent_id IS NOT NULL
              AND constituent_id NOT LIKE '%,%'
              AND constituent_id ~ '^[0-9]+$'
        """
    ] ;

    rr:subjectMap [
        rr:template "https://moma.org/resource/artwork/{object_id}" ;
        rr:class moma:Artwork
    ] ;

    # moma:hasCredit — links the artwork to its ArtworkCredit node
    rr:predicateObjectMap [
        rr:predicate moma:hasCredit ;
        rr:objectMap [
            rr:template "https://moma.org/resource/artworkcredit/{object_id}"
        ]
    ] .