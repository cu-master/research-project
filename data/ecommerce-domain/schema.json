{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://api.mystore.com/schemas/master-ecommerce.json",
    "title": "E-Commerce Master Schema",
    "description": "Complete schema definition for the e-commerce domain model including Customer, Product, Order, and Payment entities.",
    "type": "object",
    "definitions": {
        "___SHARED_TYPES___": {
            "comment": "Reusable basic types to ensure consistency",
            "id": {
                "type": "integer",
                "minimum": 1
            },
            "money": {
                "type": "number",
                "minimum": 0.00
            },
            "currency_code": {
                "type": "string",
                "pattern": "^[A-Z]{3}$",
                "description": "ISO 4217 Currency Code (e.g., USD, EUR)"
            },
            "iso_date": {
                "type": "string",
                "format": "date-time"
            }
        },
        "category": {
            "type": "object",
            "required": [
                "category_id",
                "name"
            ],
            "properties": {
                "category_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100
                },
                "description": {
                    "type": "string"
                },
                "parent_category_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id",
                    "description": "Self-referencing ID for sub-categories"
                }
            }
        },
        "product": {
            "type": "object",
            "required": [
                "product_id",
                "sku",
                "name",
                "category_id",
                "current_price"
            ],
            "properties": {
                "product_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "category_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "sku": {
                    "type": "string",
                    "pattern": "^[A-Z0-9\\-]+$",
                    "description": "Stock Keeping Unit (Uppercase, Numbers, Hyphens only)"
                },
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255
                },
                "description": {
                    "type": "string"
                },
                "stock_quantity": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                },
                "is_active": {
                    "type": "boolean",
                    "default": true
                },
                "current_price": {
                    "type": "object",
                    "required": [
                        "amount",
                        "currency"
                    ],
                    "properties": {
                        "amount": {
                            "$ref": "#/definitions/___SHARED_TYPES___/money"
                        },
                        "currency": {
                            "$ref": "#/definitions/___SHARED_TYPES___/currency_code"
                        }
                    }
                },
                "images": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "format": "uri"
                    }
                }
            }
        },
        "address": {
            "type": "object",
            "required": [
                "address_id",
                "street",
                "city",
                "country_code"
            ],
            "properties": {
                "address_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "customer_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "street": {
                    "type": "string",
                    "minLength": 5
                },
                "city": {
                    "type": "string",
                    "minLength": 1
                },
                "state_province": {
                    "type": "string"
                },
                "zip_code": {
                    "type": "string"
                },
                "country_code": {
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 2
                }
            }
        },
        "customer": {
            "type": "object",
            "required": [
                "customer_id",
                "email",
                "first_name",
                "last_name"
            ],
            "properties": {
                "customer_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "email": {
                    "type": "string",
                    "format": "email"
                },
                "first_name": {
                    "type": "string",
                    "minLength": 1
                },
                "last_name": {
                    "type": "string",
                    "minLength": 1
                },
                "phone": {
                    "type": "string",
                    "pattern": "^\\+?[0-9]{7,15}$"
                },
                "created_at": {
                    "$ref": "#/definitions/___SHARED_TYPES___/iso_date"
                },
                "saved_addresses": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/address"
                    }
                }
            }
        },
        "order_item": {
            "type": "object",
            "description": "The link between Order and Product with FROZEN price",
            "required": [
                "product_id",
                "quantity",
                "unit_price_frozen"
            ],
            "properties": {
                "product_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "quantity": {
                    "type": "integer",
                    "minimum": 1
                },
                "unit_price_frozen": {
                    "description": "The price of the item AT THE MOMENT of purchase. Do not look up the Product table price.",
                    "type": "number",
                    "minimum": 0
                },
                "subtotal": {
                    "type": "number",
                    "description": "Quantity * Unit Price"
                }
            }
        },
        "order": {
            "type": "object",
            "required": [
                "order_id",
                "customer_id",
                "items",
                "total_amount",
                "status"
            ],
            "properties": {
                "order_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "customer_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "shipping_address_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "order_date": {
                    "$ref": "#/definitions/___SHARED_TYPES___/iso_date"
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "PENDING",
                        "AWAITING_PAYMENT",
                        "PROCESSING",
                        "SHIPPED",
                        "DELIVERED",
                        "CANCELLED"
                    ]
                },
                "total_amount": {
                    "$ref": "#/definitions/___SHARED_TYPES___/money"
                },
                "currency": {
                    "$ref": "#/definitions/___SHARED_TYPES___/currency_code"
                },
                "items": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/definitions/order_item"
                    }
                }
            }
        },
        "payment": {
            "type": "object",
            "required": [
                "payment_id",
                "order_id",
                "amount",
                "payment_method",
                "status"
            ],
            "properties": {
                "payment_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "order_id": {
                    "$ref": "#/definitions/___SHARED_TYPES___/id"
                },
                "amount": {
                    "$ref": "#/definitions/___SHARED_TYPES___/money"
                },
                "payment_date": {
                    "$ref": "#/definitions/___SHARED_TYPES___/iso_date"
                },
                "payment_method": {
                    "type": "string",
                    "enum": [
                        "CREDIT_CARD",
                        "PAYPAL",
                        "WIRE_TRANSFER",
                        "GIFT_CARD"
                    ]
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "SUCCESS",
                        "FAILED",
                        "PENDING",
                        "REFUNDED"
                    ]
                },
                "gateway_transaction_id": {
                    "type": "string",
                    "description": "External ID from Stripe/PayPal for reconciliation"
                }
            }
        }
    }
}