@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <http://example.org/ontology/> .

<#AircraftTriplesMap>
  rr:logicalTable [ rr:tableName "acft_data" ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/aircraft/{acft_code}" ;
    rr:class ex:Aircraft
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:aircraftCode ;
    rr:objectMap [ rr:column "acft_code" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:model ;
    rr:objectMap [ rr:column "acft_model" ; rr:datatype xsd:string ] # JSONB column mapped as string
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:range ;
    rr:objectMap [ rr:column "acft_range" ; rr:datatype xsd:integer ]
  ] .

<#AirportTriplesMap>
  rr:logicalTable [ rr:tableName "arpt_data" ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/airport/{arpt_code}" ;
    rr:class ex:Airport
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:airportCode ;
    rr:objectMap [ rr:column "arpt_code" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:airportName ;
    rr:objectMap [ rr:column "arpt_name" ; rr:datatype xsd:string ] # JSONB column mapped as string
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:city ;
    rr:objectMap [ rr:column "arpt_city" ; rr:datatype xsd:string ] # JSONB column mapped as string
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:coordinates ;
    rr:objectMap [ rr:column "arpt_coords" ; rr:datatype xsd:string ] # Point type mapped as string
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:timezone ;
    rr:objectMap [ rr:column "arpt_tz" ; rr:datatype xsd:string ]
  ] .

<#BookingTriplesMap>
  rr:logicalTable [ rr:tableName "bkg_master" ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/booking/{bkg_ref}" ;
    rr:class ex:Booking
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:bookingReference ;
    rr:objectMap [ rr:column "bkg_ref" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:bookingDate ;
    rr:objectMap [ rr:column "bkg_date" ; rr:datatype xsd:dateTime ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:totalAmount ;
    rr:objectMap [ rr:column "total_amt" ; rr:datatype xsd:decimal ]
  ] .

<#TicketTriplesMap>
  rr:logicalTable [ rr:tableName "tkt_detail" ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/ticket/{tkt_no}" ;
    rr:class ex:Ticket
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:ticketNumber ;
    rr:objectMap [ rr:column "tkt_no" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:passengerId ;
    rr:objectMap [ rr:column "passngr_id" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:passengerName ;
    rr:objectMap [ rr:column "passngr_name" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:contactData ;
    rr:objectMap [ rr:column "contact_dat" ; rr:datatype xsd:string ] # JSONB column mapped as string
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:belongsToBooking ;
    rr:objectMap [
      rr:parentTriplesMap <#BookingTriplesMap> ;
      rr:joinCondition [ rr:child "bkg_ref" ; rr:parent "bkg_ref" ]
    ]
  ] .

<#FlightTriplesMap>
  rr:logicalTable [ rr:tableName "flt_trans" ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/flight/{flt_id}" ;
    rr:class ex:Flight
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:flightId ;
    rr:objectMap [ rr:column "flt_id" ; rr:datatype xsd:integer ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:flightNumber ;
    rr:objectMap [ rr:column "flt_no" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:scheduledDeparture ;
    rr:objectMap [ rr:column "sched_dept" ; rr:datatype xsd:dateTime ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:scheduledArrival ;
    rr:objectMap [ rr:column "sched_arr" ; rr:datatype xsd:dateTime ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:status ;
    rr:objectMap [ rr:column "flt_status" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:actualDeparture ;
    rr:objectMap [ rr:column "actual_dept" ; rr:datatype xsd:dateTime ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:actualArrival ;
    rr:objectMap [ rr:column "actual_arr" ; rr:datatype xsd:dateTime ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:departureAirport ;
    rr:objectMap [
      rr:parentTriplesMap <#AirportTriplesMap> ;
      rr:joinCondition [ rr:child "dept_arpt" ; rr:parent "arpt_code" ]
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:arrivalAirport ;
    rr:objectMap [
      rr:parentTriplesMap <#AirportTriplesMap> ;
      rr:joinCondition [ rr:child "arr_arpt" ; rr:parent "arpt_code" ]
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:operatedBy ;
    rr:objectMap [
      rr:parentTriplesMap <#AircraftTriplesMap> ;
      rr:joinCondition [ rr:child "acft_code" ; rr:parent "acft_code" ]
    ]
  ] .

<#TicketFlightTriplesMap>
  rr:logicalTable [ rr:tableName "tkt_flt_detail" ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/ticket_flight/{tkt_no}/{flt_id}" ;
    rr:class ex:TicketFlight
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:fareConditions ;
    rr:objectMap [ rr:column "fare_cond" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:amount ;
    rr:objectMap [ rr:column "tkt_amt" ; rr:datatype xsd:decimal ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:onTicket ;
    rr:objectMap [
      rr:parentTriplesMap <#TicketTriplesMap> ;
      rr:joinCondition [ rr:child "tkt_no" ; rr:parent "tkt_no" ]
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:forFlight ;
    rr:objectMap [
      rr:parentTriplesMap <#FlightTriplesMap> ;
      rr:joinCondition [ rr:child "flt_id" ; rr:parent "flt_id" ]
    ]
  ] .

<#BoardingPassTriplesMap>
  rr:logicalTable [ rr:tableName "brd_pass" ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/boarding_pass/{tkt_no}/{flt_id}" ;
    rr:class ex:BoardingPass
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:boardingNumber ;
    rr:objectMap [ rr:column "brd_no" ; rr:datatype xsd:integer ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:seatNumber ;
    rr:objectMap [ rr:column "seat_no" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:forTicketFlight ;
    rr:objectMap [
      rr:parentTriplesMap <#TicketFlightTriplesMap> ;
      rr:joinCondition [ rr:child "tkt_no" ; rr:parent "tkt_no" ] ;
      rr:joinCondition [ rr:child "flt_id" ; rr:parent "flt_id" ]
    ]
  ] .

<#SeatTriplesMap>
  rr:logicalTable [ rr:tableName "seat_ref" ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/seat/{acft_code}/{seat_no}" ;
    rr:class ex:Seat
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:seatNumber ;
    rr:objectMap [ rr:column "seat_no" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:fareConditions ;
    rr:objectMap [ rr:column "fare_cond" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:inAircraft ;
    rr:objectMap [
      rr:parentTriplesMap <#AircraftTriplesMap> ;
      rr:joinCondition [ rr:child "acft_code" ; rr:parent "acft_code" ]
    ]
  ] .