@prefix rr:  <http://www.w3.org/ns/r2rml#> .
@prefix ex:  <http://example.org/ontology/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<#ActorTriplesMap>
  rr:logicalTable [ rr:tableName "actor" ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/actor/{actor_id}" ;
    rr:class ex:Actor
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:actorId ;
    rr:objectMap [ rr:column "actor_id" ; rr:datatype xsd:integer ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:firstName ;
    rr:objectMap [ rr:column "first_name" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:lastName ;
    rr:objectMap [ rr:column "last_name" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:lastUpdate ;
    rr:objectMap [ rr:column "last_update" ; rr:datatype xsd:dateTime ]
  ] .

<#AddressTriplesMap>
  rr:logicalTable [ rr:tableName "address" ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/address/{address_id}" ;
    rr:class ex:Address
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:addressId ;
    rr:objectMap [ rr:column "address_id" ; rr:datatype xsd:integer ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:addressLine1 ;
    rr:objectMap [ rr:column "address" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:addressLine2 ;
    rr:objectMap [ rr:column "address2" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:district ;
    rr:objectMap [ rr:column "district" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:postalCode ;
    rr:objectMap [ rr:column "postal_code" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:phone ;
    rr:objectMap [ rr:column "phone" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:lastUpdate ;
    rr:objectMap [ rr:column "last_update" ; rr:datatype xsd:dateTime ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:city ;
    rr:objectMap [
      rr:parentTriplesMap <#CityTriplesMap> ;
      rr:joinCondition [ rr:child "city_id" ; rr:parent "city_id" ]
    ]
  ] .

<#CategoryTriplesMap>
  rr:logicalTable [ rr:tableName "category" ] ;
  rr:subjectMap [
