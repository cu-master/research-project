  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:active ;
    rr:objectMap [
      rr:column "active" ;
      rr:datatype xsd:integer
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:address ;
    rr:objectMap [
      rr:parentTriplesMap <#AddressTriplesMap> ;
      rr:joinCondition [ rr:child "address_id" ; rr:parent "address_id" ]
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:store ;
