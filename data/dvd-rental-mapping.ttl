  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:lastUpdate ;
    rr:objectMap [ rr:column "last_update" ; rr:datatype xsd:dateTime ]
  ] .

<#CityTriplesMap>
  rr:logicalTable [ rr:tableName "city" ] ;
