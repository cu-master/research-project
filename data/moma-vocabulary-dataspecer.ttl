@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix moma:  <https://moma.org/ontology/> .

# ─────────────────────────────────────────────
# Ontology declaration
# ─────────────────────────────────────────────

<https://moma.org/ontology/>
    a owl:Ontology ;
    rdfs:label "MoMA Collection Ontology"@en ;
    dcterms:description "Semantic vocabulary for the Museum of Modern Art collection management system, covering artworks, artists, exhibitions, acquisitions, loans, provenance, conservation and media."@en ;
    owl:versionInfo "1.0.0" .


# ═════════════════════════════════════════════
# CLASSES
# ═════════════════════════════════════════════

moma:Artwork
    a owl:Class ;
    rdfs:label "Artwork"@en ;
    rdfs:comment "A physical or digital object held in the MoMA collection, identified by a unique accession number."@en .

moma:Artist
    a owl:Class ;
    rdfs:label "Artist"@en ;
    rdfs:comment "A person or group credited with the creation of one or more artworks in the collection."@en .

moma:ArtworkCredit
    a owl:Class ;
    rdfs:label "Artwork credit"@en ;
    rdfs:comment "An attribution linking an artist to an artwork, specifying their role and display order when multiple creators are credited."@en .

moma:Department
    a owl:Class ;
    rdfs:label "Department"@en ;
    rdfs:comment "A curatorial division of the museum (e.g. Photography, Painting and Sculpture) that owns artworks and organises exhibitions."@en .

moma:Location
    a owl:Class ;
    rdfs:label "Location"@en ;
    rdfs:comment "A physical place within the museum — a named gallery on a specific floor and wing, or a storage facility."@en .

moma:Exhibition
    a owl:Class ;
    rdfs:label "Exhibition"@en ;
    rdfs:comment "A named show presented by the museum, with defined start and end dates and an organising department."@en .

moma:ExhibitionPresentation
    a owl:Class ;
    rdfs:label "Exhibition presentation"@en ;
    rdfs:comment "The appearance of a specific artwork within a specific exhibition, including its display dates and wall label text."@en .

moma:Loan
    a owl:Class ;
    rdfs:label "Loan"@en ;
    rdfs:comment "An outgoing loan of an artwork to an external institution, tracked from dispatch to return."@en .

moma:Acquisition
    a owl:Class ;
    rdfs:label "Acquisition"@en ;
    rdfs:comment "The event by which an artwork officially entered the MoMA collection, recording method, source, price and funding."@en .

moma:ProvenanceRecord
    a owl:Class ;
    rdfs:label "Provenance record"@en ;
    rdfs:comment "A single link in the ownership chain of an artwork, covering one prior owner and the period of their ownership."@en .

moma:ConservationRecord
    a owl:Class ;
    rdfs:label "Conservation record"@en ;
    rdfs:comment "A formal examination or treatment report for an artwork, filed by a conservator."@en .

moma:Conservator
    a owl:Class ;
    rdfs:label "Conservator"@en ;
    rdfs:comment "A museum staff member who examines and treats artworks; each has a named specialisation."@en .

moma:MediaAsset
    a owl:Class ;
    rdfs:label "Media asset"@en ;
    rdfs:comment "A digital file (photograph, video, 3D scan) associated with an artwork."@en .


# ═════════════════════════════════════════════
# OBJECT PROPERTIES  (links between classes)
# ═════════════════════════════════════════════

# --- Artwork ↔ Artist (via ArtworkCredit) ---

moma:creditedArtwork
    a owl:ObjectProperty ;
    rdfs:label "credited artwork"@en ;
    rdfs:comment "The artwork to which this credit record belongs."@en ;
    rdfs:domain moma:ArtworkCredit ;
    rdfs:range  moma:Artwork .

moma:creditedArtist
    a owl:ObjectProperty ;
    rdfs:label "credited artist"@en ;
    rdfs:comment "The artist named in this credit record."@en ;
    rdfs:domain moma:ArtworkCredit ;
    rdfs:range  moma:Artist .

moma:hasCredit
    a owl:ObjectProperty ;
    rdfs:label "has credit"@en ;
    rdfs:comment "Links an artwork to one of its attribution records."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  moma:ArtworkCredit ;
    owl:inverseOf moma:creditedArtwork .

# --- Artwork → Department / Location ---

moma:belongsToDepartment
    a owl:ObjectProperty ;
    rdfs:label "belongs to department"@en ;
    rdfs:comment "The curatorial department responsible for this artwork."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  moma:Department .

moma:currentLocation
    a owl:ObjectProperty ;
    rdfs:label "current location"@en ;
    rdfs:comment "The gallery or storage area where the artwork is currently held."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  moma:Location .

# --- Exhibition ---

moma:organisedBy
    a owl:ObjectProperty ;
    rdfs:label "organised by"@en ;
    rdfs:comment "The department responsible for staging this exhibition."@en ;
    rdfs:domain moma:Exhibition ;
    rdfs:range  moma:Department .

moma:featuredIn
    a owl:ObjectProperty ;
    rdfs:label "featured in"@en ;
    rdfs:comment "Links an artwork to a presentation record within an exhibition."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  moma:ExhibitionPresentation .

moma:presentationExhibition
    a owl:ObjectProperty ;
    rdfs:label "presentation exhibition"@en ;
    rdfs:comment "The exhibition in which this presentation took place."@en ;
    rdfs:domain moma:ExhibitionPresentation ;
    rdfs:range  moma:Exhibition .

moma:presentationArtwork
    a owl:ObjectProperty ;
    rdfs:label "presentation artwork"@en ;
    rdfs:comment "The artwork shown in this presentation."@en ;
    rdfs:domain moma:ExhibitionPresentation ;
    rdfs:range  moma:Artwork .

# --- Loan ---

moma:loanedArtwork
    a owl:ObjectProperty ;
    rdfs:label "loaned artwork"@en ;
    rdfs:comment "The artwork that is the subject of this loan."@en ;
    rdfs:domain moma:Loan ;
    rdfs:range  moma:Artwork .

# --- Acquisition ---

moma:acquiredArtwork
    a owl:ObjectProperty ;
    rdfs:label "acquired artwork"@en ;
    rdfs:comment "The artwork brought into the collection via this acquisition."@en ;
    rdfs:domain moma:Acquisition ;
    rdfs:range  moma:Artwork .

moma:supportedByProvenance
    a owl:ObjectProperty ;
    rdfs:label "supported by provenance"@en ;
    rdfs:comment "The provenance record that validated ownership history for this acquisition."@en ;
    rdfs:domain moma:Acquisition ;
    rdfs:range  moma:ProvenanceRecord .

# --- Provenance ---

moma:provenanceOf
    a owl:ObjectProperty ;
    rdfs:label "provenance of"@en ;
    rdfs:comment "The artwork whose ownership history this record describes."@en ;
    rdfs:domain moma:ProvenanceRecord ;
    rdfs:range  moma:Artwork .

# --- Conservation ---

moma:conservationOf
    a owl:ObjectProperty ;
    rdfs:label "conservation of"@en ;
    rdfs:comment "The artwork examined or treated in this conservation record."@en ;
    rdfs:domain moma:ConservationRecord ;
    rdfs:range  moma:Artwork .

moma:filedBy
    a owl:ObjectProperty ;
    rdfs:label "filed by"@en ;
    rdfs:comment "The conservator who conducted the examination and wrote this record."@en ;
    rdfs:domain moma:ConservationRecord ;
    rdfs:range  moma:Conservator .

# --- Media ---

moma:mediaOf
    a owl:ObjectProperty ;
    rdfs:label "media of"@en ;
    rdfs:comment "The artwork this media asset documents."@en ;
    rdfs:domain moma:MediaAsset ;
    rdfs:range  moma:Artwork .

# --- Department head ---

moma:headCurator
    a owl:ObjectProperty ;
    rdfs:label "head curator"@en ;
    rdfs:comment "The artist/constituent record for the curator who leads this department."@en ;
    rdfs:domain moma:Department ;
    rdfs:range  moma:Artist .


# ═════════════════════════════════════════════
# DATATYPE PROPERTIES  (literal attributes)
# ═════════════════════════════════════════════

# ── Artwork ──────────────────────────────────

moma:objectId
    a owl:DatatypeProperty ;
    rdfs:label "object ID"@en ;
    rdfs:comment "Unique numeric identifier for the artwork in the MoMA collection database."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:integer .

moma:title
    a owl:DatatypeProperty ;
    rdfs:label "title"@en ;
    rdfs:comment "The title of the artwork as catalogued."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:string .

moma:medium
    a owl:DatatypeProperty ;
    rdfs:label "medium"@en ;
    rdfs:comment "The materials and techniques used to create the artwork (e.g. 'Oil on canvas')."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:string .

moma:classification
    a owl:DatatypeProperty ;
    rdfs:label "classification"@en ;
    rdfs:comment "Broad category assigned by the museum (e.g. Painting, Photograph, Print)."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:string .

moma:artworkDate
    a owl:DatatypeProperty ;
    rdfs:label "artwork date"@en ;
    rdfs:comment "The date or date range when the artwork was created, as a free-text string."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:string .

moma:dimensions
    a owl:DatatypeProperty ;
    rdfs:label "dimensions"@en ;
    rdfs:comment "Human-readable description of the artwork's physical dimensions."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:string .

moma:accessionNumber
    a owl:DatatypeProperty ;
    rdfs:label "accession number"@en ;
    rdfs:comment "The museum's unique registration code for this object."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:string .

moma:creditLine
    a owl:DatatypeProperty ;
    rdfs:label "credit line"@en ;
    rdfs:comment "The formal attribution text used in catalogue entries and wall labels."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:string .

moma:onView
    a owl:DatatypeProperty ;
    rdfs:label "on view"@en ;
    rdfs:comment "Whether the artwork is currently on public display."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:boolean .

moma:momaUrl
    a owl:DatatypeProperty ;
    rdfs:label "MoMA URL"@en ;
    rdfs:comment "URL of the artwork's page on the MoMA website."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:anyURI .

moma:heightCm
    a owl:DatatypeProperty ;
    rdfs:label "height (cm)"@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:decimal .

moma:widthCm
    a owl:DatatypeProperty ;
    rdfs:label "width (cm)"@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:decimal .

moma:depthCm
    a owl:DatatypeProperty ;
    rdfs:label "depth (cm)"@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:decimal .

moma:weightKg
    a owl:DatatypeProperty ;
    rdfs:label "weight (kg)"@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:decimal .

moma:durationSec
    a owl:DatatypeProperty ;
    rdfs:label "duration (seconds)"@en ;
    rdfs:comment "For time-based media: total running time in seconds."@en ;
    rdfs:domain moma:Artwork ;
    rdfs:range  xsd:integer .

# ── Artist ───────────────────────────────────

moma:constituentId
    a owl:DatatypeProperty ;
    rdfs:label "constituent ID"@en ;
    rdfs:comment "Unique numeric identifier for the artist in the MoMA constituent database."@en ;
    rdfs:domain moma:Artist ;
    rdfs:range  xsd:integer .

moma:artistName
    a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:domain moma:Artist ;
    rdfs:range  xsd:string .

moma:biography
    a owl:DatatypeProperty ;
    rdfs:label "biography"@en ;
    rdfs:domain moma:Artist ;
    rdfs:range  xsd:string .

moma:nationality
    a owl:DatatypeProperty ;
    rdfs:label "nationality"@en ;
    rdfs:domain moma:Artist ;
    rdfs:range  xsd:string .

moma:gender
    a owl:DatatypeProperty ;
    rdfs:label "gender"@en ;
    rdfs:domain moma:Artist ;
    rdfs:range  xsd:string .

moma:birthYear
    a owl:DatatypeProperty ;
    rdfs:label "birth year"@en ;
    rdfs:domain moma:Artist ;
    rdfs:range  xsd:gYear .

moma:deathYear
    a owl:DatatypeProperty ;
    rdfs:label "death year"@en ;
    rdfs:domain moma:Artist ;
    rdfs:range  xsd:gYear .

moma:wikiQid
    a owl:DatatypeProperty ;
    rdfs:label "Wikidata QID"@en ;
    rdfs:comment "Wikidata entity identifier (e.g. Q5598)."@en ;
    rdfs:domain moma:Artist ;
    rdfs:range  xsd:string .

moma:ulanId
    a owl:DatatypeProperty ;
    rdfs:label "ULAN ID"@en ;
    rdfs:comment "Getty Union List of Artist Names identifier."@en ;
    rdfs:domain moma:Artist ;
    rdfs:range  xsd:string .

# ── ArtworkCredit ────────────────────────────

moma:creditRole
    a owl:DatatypeProperty ;
    rdfs:label "role"@en ;
    rdfs:comment "The creator's role for this artwork (e.g. Artist, Architect, Designer, Manufacturer)."@en ;
    rdfs:domain moma:ArtworkCredit ;
    rdfs:range  xsd:string .

moma:displayOrder
    a owl:DatatypeProperty ;
    rdfs:label "display order"@en ;
    rdfs:comment "Integer controlling the order in which credited artists are listed."@en ;
    rdfs:domain moma:ArtworkCredit ;
    rdfs:range  xsd:integer .

# ── Department ───────────────────────────────

moma:departmentId
    a owl:DatatypeProperty ;
    rdfs:label "department ID"@en ;
    rdfs:domain moma:Department ;
    rdfs:range  xsd:integer .

moma:departmentName
    a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:domain moma:Department ;
    rdfs:range  xsd:string .

moma:departmentDescription
    a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:domain moma:Department ;
    rdfs:range  xsd:string .

# ── Location ─────────────────────────────────

moma:locationId
    a owl:DatatypeProperty ;
    rdfs:label "location ID"@en ;
    rdfs:domain moma:Location ;
    rdfs:range  xsd:integer .

moma:galleryName
    a owl:DatatypeProperty ;
    rdfs:label "gallery name"@en ;
    rdfs:domain moma:Location ;
    rdfs:range  xsd:string .

moma:floor
    a owl:DatatypeProperty ;
    rdfs:label "floor"@en ;
    rdfs:domain moma:Location ;
    rdfs:range  xsd:string .

moma:wing
    a owl:DatatypeProperty ;
    rdfs:label "wing"@en ;
    rdfs:domain moma:Location ;
    rdfs:range  xsd:string .

moma:building
    a owl:DatatypeProperty ;
    rdfs:label "building"@en ;
    rdfs:domain moma:Location ;
    rdfs:range  xsd:string .

moma:isStorage
    a owl:DatatypeProperty ;
    rdfs:label "is storage"@en ;
    rdfs:comment "True if this location is a storage facility not open to the public."@en ;
    rdfs:domain moma:Location ;
    rdfs:range  xsd:boolean .

# ── Exhibition ───────────────────────────────

moma:exhibitionId
    a owl:DatatypeProperty ;
    rdfs:label "exhibition ID"@en ;
    rdfs:domain moma:Exhibition ;
    rdfs:range  xsd:integer .

moma:exhibitionTitle
    a owl:DatatypeProperty ;
    rdfs:label "title"@en ;
    rdfs:domain moma:Exhibition ;
    rdfs:range  xsd:string .

moma:startDate
    a owl:DatatypeProperty ;
    rdfs:label "start date"@en ;
    rdfs:domain moma:Exhibition ;
    rdfs:range  xsd:date .

moma:endDate
    a owl:DatatypeProperty ;
    rdfs:label "end date"@en ;
    rdfs:domain moma:Exhibition ;
    rdfs:range  xsd:date .

moma:venue
    a owl:DatatypeProperty ;
    rdfs:label "venue"@en ;
    rdfs:comment "The name of the host institution if the exhibition travels outside MoMA."@en ;
    rdfs:domain moma:Exhibition ;
    rdfs:range  xsd:string .

moma:curator
    a owl:DatatypeProperty ;
    rdfs:label "curator"@en ;
    rdfs:comment "Free-text name of the lead curator for this exhibition."@en ;
    rdfs:domain moma:Exhibition ;
    rdfs:range  xsd:string .

# ── ExhibitionPresentation ───────────────────

moma:displayStart
    a owl:DatatypeProperty ;
    rdfs:label "display start"@en ;
    rdfs:domain moma:ExhibitionPresentation ;
    rdfs:range  xsd:date .

moma:displayEnd
    a owl:DatatypeProperty ;
    rdfs:label "display end"@en ;
    rdfs:domain moma:ExhibitionPresentation ;
    rdfs:range  xsd:date .

moma:wallLabel
    a owl:DatatypeProperty ;
    rdfs:label "wall label"@en ;
    rdfs:comment "The interpretive text displayed beside the artwork in this exhibition."@en ;
    rdfs:domain moma:ExhibitionPresentation ;
    rdfs:range  xsd:string .

# ── Loan ─────────────────────────────────────

moma:loanId
    a owl:DatatypeProperty ;
    rdfs:label "loan ID"@en ;
    rdfs:domain moma:Loan ;
    rdfs:range  xsd:integer .

moma:borrowingInstitution
    a owl:DatatypeProperty ;
    rdfs:label "borrowing institution"@en ;
    rdfs:domain moma:Loan ;
    rdfs:range  xsd:string .

moma:loanStart
    a owl:DatatypeProperty ;
    rdfs:label "loan start"@en ;
    rdfs:domain moma:Loan ;
    rdfs:range  xsd:date .

moma:loanEnd
    a owl:DatatypeProperty ;
    rdfs:label "loan end"@en ;
    rdfs:domain moma:Loan ;
    rdfs:range  xsd:date .

moma:loanStatus
    a owl:DatatypeProperty ;
    rdfs:label "loan status"@en ;
    rdfs:comment "Current status of the loan: pending, active, returned, cancelled."@en ;
    rdfs:domain moma:Loan ;
    rdfs:range  xsd:string .

moma:insuranceValue
    a owl:DatatypeProperty ;
    rdfs:label "insurance value"@en ;
    rdfs:domain moma:Loan ;
    rdfs:range  xsd:string .

moma:conditionOut
    a owl:DatatypeProperty ;
    rdfs:label "condition on departure"@en ;
    rdfs:domain moma:Loan ;
    rdfs:range  xsd:string .

moma:conditionIn
    a owl:DatatypeProperty ;
    rdfs:label "condition on return"@en ;
    rdfs:domain moma:Loan ;
    rdfs:range  xsd:string .

# ── Acquisition ──────────────────────────────

moma:acquisitionId
    a owl:DatatypeProperty ;
    rdfs:label "acquisition ID"@en ;
    rdfs:domain moma:Acquisition ;
    rdfs:range  xsd:integer .

moma:acquiredDate
    a owl:DatatypeProperty ;
    rdfs:label "acquired date"@en ;
    rdfs:domain moma:Acquisition ;
    rdfs:range  xsd:date .

moma:acquisitionMethod
    a owl:DatatypeProperty ;
    rdfs:label "acquisition method"@en ;
    rdfs:comment "How the artwork was acquired: purchase, gift, bequest, transfer."@en ;
    rdfs:domain moma:Acquisition ;
    rdfs:range  xsd:string .

moma:acquisitionSource
    a owl:DatatypeProperty ;
    rdfs:label "source"@en ;
    rdfs:comment "The name of the donor, seller or transferring institution."@en ;
    rdfs:domain moma:Acquisition ;
    rdfs:range  xsd:string .

moma:price
    a owl:DatatypeProperty ;
    rdfs:label "price"@en ;
    rdfs:domain moma:Acquisition ;
    rdfs:range  xsd:string .

moma:fundingSource
    a owl:DatatypeProperty ;
    rdfs:label "funding source"@en ;
    rdfs:comment "The fund or donor that covered the acquisition cost."@en ;
    rdfs:domain moma:Acquisition ;
    rdfs:range  xsd:string .

# ── ProvenanceRecord ─────────────────────────

moma:provenanceId
    a owl:DatatypeProperty ;
    rdfs:label "provenance ID"@en ;
    rdfs:domain moma:ProvenanceRecord ;
    rdfs:range  xsd:integer .

moma:ownerName
    a owl:DatatypeProperty ;
    rdfs:label "owner name"@en ;
    rdfs:domain moma:ProvenanceRecord ;
    rdfs:range  xsd:string .

moma:ownerAcquiredDate
    a owl:DatatypeProperty ;
    rdfs:label "owner acquired date"@en ;
    rdfs:domain moma:ProvenanceRecord ;
    rdfs:range  xsd:date .

moma:ownerSoldDate
    a owl:DatatypeProperty ;
    rdfs:label "owner sold date"@en ;
    rdfs:domain moma:ProvenanceRecord ;
    rdfs:range  xsd:date .

moma:ownerLocation
    a owl:DatatypeProperty ;
    rdfs:label "owner location"@en ;
    rdfs:domain moma:ProvenanceRecord ;
    rdfs:range  xsd:string .

moma:provenanceNotes
    a owl:DatatypeProperty ;
    rdfs:label "notes"@en ;
    rdfs:domain moma:ProvenanceRecord ;
    rdfs:range  xsd:string .

moma:verified
    a owl:DatatypeProperty ;
    rdfs:label "verified"@en ;
    rdfs:comment "Whether the ownership record has been independently verified."@en ;
    rdfs:domain moma:ProvenanceRecord ;
    rdfs:range  xsd:boolean .

# ── ConservationRecord ───────────────────────

moma:conservationId
    a owl:DatatypeProperty ;
    rdfs:label "conservation record ID"@en ;
    rdfs:domain moma:ConservationRecord ;
    rdfs:range  xsd:integer .

moma:examinationDate
    a owl:DatatypeProperty ;
    rdfs:label "examination date"@en ;
    rdfs:domain moma:ConservationRecord ;
    rdfs:range  xsd:date .

moma:conditionRating
    a owl:DatatypeProperty ;
    rdfs:label "condition rating"@en ;
    rdfs:comment "Overall condition assessment: Excellent, Good, Fair, Poor."@en ;
    rdfs:domain moma:ConservationRecord ;
    rdfs:range  xsd:string .

moma:findings
    a owl:DatatypeProperty ;
    rdfs:label "findings"@en ;
    rdfs:domain moma:ConservationRecord ;
    rdfs:range  xsd:string .

moma:treatment
    a owl:DatatypeProperty ;
    rdfs:label "treatment"@en ;
    rdfs:domain moma:ConservationRecord ;
    rdfs:range  xsd:string .

moma:materialsUsed
    a owl:DatatypeProperty ;
    rdfs:label "materials used"@en ;
    rdfs:domain moma:ConservationRecord ;
    rdfs:range  xsd:string .

moma:nextReview
    a owl:DatatypeProperty ;
    rdfs:label "next review date"@en ;
    rdfs:domain moma:ConservationRecord ;
    rdfs:range  xsd:date .

# ── Conservator ──────────────────────────────

moma:conservatorId
    a owl:DatatypeProperty ;
    rdfs:label "conservator ID"@en ;
    rdfs:domain moma:Conservator ;
    rdfs:range  xsd:integer .

moma:conservatorName
    a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:domain moma:Conservator ;
    rdfs:range  xsd:string .

moma:specialization
    a owl:DatatypeProperty ;
    rdfs:label "specialization"@en ;
    rdfs:comment "Area of conservation expertise, e.g. Paintings, Works on Paper, Time-based Media."@en ;
    rdfs:domain moma:Conservator ;
    rdfs:range  xsd:string .

moma:conservatorDepartment
    a owl:DatatypeProperty ;
    rdfs:label "department"@en ;
    rdfs:domain moma:Conservator ;
    rdfs:range  xsd:string .

moma:email
    a owl:DatatypeProperty ;
    rdfs:label "email"@en ;
    rdfs:domain moma:Conservator ;
    rdfs:range  xsd:string .

# ── MediaAsset ───────────────────────────────

moma:mediaId
    a owl:DatatypeProperty ;
    rdfs:label "media ID"@en ;
    rdfs:domain moma:MediaAsset ;
    rdfs:range  xsd:integer .

moma:mediaUrl
    a owl:DatatypeProperty ;
    rdfs:label "URL"@en ;
    rdfs:domain moma:MediaAsset ;
    rdfs:range  xsd:anyURI .

moma:mediaType
    a owl:DatatypeProperty ;
    rdfs:label "media type"@en ;
    rdfs:comment "Type of file: photograph, video, 3d-scan, audio."@en ;
    rdfs:domain moma:MediaAsset ;
    rdfs:range  xsd:string .

moma:caption
    a owl:DatatypeProperty ;
    rdfs:label "caption"@en ;
    rdfs:domain moma:MediaAsset ;
    rdfs:range  xsd:string .

moma:isPrimary
    a owl:DatatypeProperty ;
    rdfs:label "is primary"@en ;
    rdfs:comment "True if this is the default display image for the artwork."@en ;
    rdfs:domain moma:MediaAsset ;
    rdfs:range  xsd:boolean .

moma:mediaCreatedDate
    a owl:DatatypeProperty ;
    rdfs:label "created date"@en ;
    rdfs:domain moma:MediaAsset ;
    rdfs:range  xsd:date .
