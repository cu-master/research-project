@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://example.com/sk19-ecommerce#> .

# TriplesMap for Addresses table
<#AddressesTriplesMap>
  a rr:TriplesMap;
  rr:logicalTable [ rr:tableName "addresses" ];
  rr:subjectMap [
    rr:template "http://example.com/sk19-ecommerce/Addresses/{address_id}";
    rr:class ex:Addresses;
  ];
  # Column mappings
  rr:predicateObjectMap [
    rr:predicate ex:address_id;
    rr:objectMap [ rr:column "address_id"; rr:datatype xsd:integer ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:customer_id; # Maps to the literal ID of the customer
    rr:objectMap [ rr:column "customer_id"; rr:datatype xsd:integer ];
    # The ex:has (Customers to Addresses) relationship is mapped from CustomersTriplesMap.
  ];
  rr:predicateObjectMap [
    rr:predicate ex:street;
    rr:objectMap [ rr:column "street"; rr:datatype xsd:string ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:city;
    rr:objectMap [ rr:column "city"; rr:datatype xsd:string ];
  ].

# TriplesMap for Categories table
<#CategoriesTriplesMap>
  a rr:TriplesMap;
  rr:logicalTable [ rr:tableName "categories" ];
  rr:subjectMap [
    rr:template "http://example.com/sk19-ecommerce/Categories/{category_id}";
    rr:class ex:Categories;
  ];
  # Column mappings
  rr:predicateObjectMap [
    rr:predicate ex:category_id;
    rr:objectMap [ rr:column "category_id"; rr:datatype xsd:integer ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:name;
    rr:objectMap [ rr:column "name"; rr:datatype xsd:string ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:description;
    rr:objectMap [ rr:column "description"; rr:datatype xsd:string ];
  ].

# TriplesMap for Customers table
<#CustomersTriplesMap>
  a rr:TriplesMap;
  rr:logicalTable [ rr:tableName "customers" ];
  rr:subjectMap [
    rr:template "http://example.com/sk19-ecommerce/Customers/{customer_id}";
    rr:class ex:Customers;
  ];
  # Column mappings
  rr:predicateObjectMap [
    rr:predicate ex:customer_id;
    rr:objectMap [ rr:column "customer_id"; rr:datatype xsd:integer ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:email;
    rr:objectMap [ rr:column "email"; rr:datatype xsd:string ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:name;
    rr:objectMap [ rr:column "name"; rr:datatype xsd:string ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:created_at;
    rr:objectMap [ rr:column "created_at"; rr:datatype xsd:dateTimeStamp ];
  ];
  # Foreign key relationships (Customer has Addresses)
  rr:predicateObjectMap [
    rr:predicate ex:has;
    rr:objectMap [
      rr:parentTriplesMap <#AddressesTriplesMap>;
      rr:joinCondition [
        rr:child "customer_id";
        rr:parent "customer_id";
      ];
    ];
  ].

# TriplesMap for Order_items table
<#OrderItemsTriplesMap>
  a rr:TriplesMap;
  rr:logicalTable [ rr:tableName "order_items" ];
  rr:subjectMap [
    rr:template "http://example.com/sk19-ecommerce/Order_items/{order_item_id}";
    rr:class ex:Order_items;
  ];
  # Column mappings
  rr:predicateObjectMap [
    rr:predicate ex:order_item_id;
    rr:objectMap [ rr:column "order_item_id"; rr:datatype xsd:integer ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:order_id; # Maps to the literal ID of the order
    rr:objectMap [ rr:column "order_id"; rr:datatype xsd:integer ];
    # The ex:contains (Orders to Order_items) relationship is mapped from OrdersTriplesMap.
  ];
  # Foreign key relationships (Order_items refers to Products)
  rr:predicateObjectMap [
    rr:predicate ex:refersTo;
    rr:objectMap [
      rr:parentTriplesMap <#ProductsTriplesMap>;
      rr:joinCondition [
        rr:child "product_id";
        rr:parent "product_id";
      ];
    ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:product_id; # Maps to the literal ID of the product
    rr:objectMap [ rr:column "product_id"; rr:datatype xsd:integer ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:quantity;
    rr:objectMap [ rr:column "quantity"; rr:datatype xsd:integer ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:unit_price;
    rr:objectMap [ rr:column "unit_price"; rr:datatype xsd:decimal ];
  ].

# TriplesMap for Orders table
<#OrdersTriplesMap>
  a rr:TriplesMap;
  rr:logicalTable [ rr:tableName "orders" ];
  rr:subjectMap [
    rr:template "http://example.com/sk19-ecommerce/Orders/{order_id}";
    rr:class ex:Orders;
  ];
  # Column mappings
  rr:predicateObjectMap [
    rr:predicate ex:order_id;
    rr:objectMap [ rr:column "order_id"; rr:datatype xsd:integer ];
  ];
  # Foreign key relationships (Orders orderedBy Customers)
  rr:predicateObjectMap [
    rr:predicate ex:orderedBy;
    rr:objectMap [
      rr:parentTriplesMap <#CustomersTriplesMap>;
      rr:joinCondition [
        rr:child "customer_id";
        rr:parent "customer_id";
      ];
    ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:customer_id; # Maps to the literal ID of the customer
    rr:objectMap [ rr:column "customer_id"; rr:datatype xsd:integer ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:order_date;
    rr:objectMap [ rr:column "order_date"; rr:datatype xsd:dateTimeStamp ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:total_amount;
    rr:objectMap [ rr:column "total_amount"; rr:datatype xsd:decimal ];
  ];
  # Foreign key relationships (Order contains Order_items)
  rr:predicateObjectMap [
    rr:predicate ex:contains;
    rr:objectMap [
      rr:parentTriplesMap <#OrderItemsTriplesMap>;
      rr:joinCondition [
        rr:child "order_id";
        rr:parent "order_id";
      ];
    ];
  ];
  # Foreign key relationships (Order has Payments)
  rr:predicateObjectMap [
    rr:predicate ex:hasPayment;
    rr:objectMap [
      rr:parentTriplesMap <#PaymentsTriplesMap>;
      rr:joinCondition [
        rr:child "order_id";
        rr:parent "order_id";
      ];
    ];
  ].

# TriplesMap for Payments table
<#PaymentsTriplesMap>
  a rr:TriplesMap;
  rr:logicalTable [ rr:tableName "payments" ];
  rr:subjectMap [
    rr:template "http://example.com/sk19-ecommerce/Payments/{payment_id}";
    rr:class ex:Payments;
  ];
  # Column mappings
  rr:predicateObjectMap [
    rr:predicate ex:payment_id;
    rr:objectMap [ rr:column "payment_id"; rr:datatype xsd:integer ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:order_id; # Maps to the literal ID of the order
    rr:objectMap [ rr:column "order_id"; rr:datatype xsd:integer ];
    # The ex:hasPayment (Orders to Payments) relationship is mapped from OrdersTriplesMap.
  ];
  rr:predicateObjectMap [
    rr:predicate ex:amount;
    rr:objectMap [ rr:column "amount"; rr:datatype xsd:decimal ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:payment_date;
    rr:objectMap [ rr:column "payment_date"; rr:datatype xsd:dateTimeStamp ];
  ].

# TriplesMap for Products table
<#ProductsTriplesMap>
  a rr:TriplesMap;
  rr:logicalTable [ rr:tableName "products" ];
  rr:subjectMap [
    rr:template "http://example.com/sk19-ecommerce/Products/{product_id}";
    rr:class ex:Products;
  ];
  # Column mappings
  rr:predicateObjectMap [
    rr:predicate ex:product_id;
    rr:objectMap [ rr:column "product_id"; rr:datatype xsd:integer ];
  ];
  # Foreign key relationships (Products isIn Categories)
  rr:predicateObjectMap [
    rr:predicate ex:isIn;
    rr:objectMap [
      rr:parentTriplesMap <#CategoriesTriplesMap>;
      rr:joinCondition [
        rr:child "category_id";
        rr:parent "category_id";
      ];
    ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:category_id; # Maps to the literal ID of the category
    rr:objectMap [ rr:column "category_id"; rr:datatype xsd:integer ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:name;
    rr:objectMap [ rr:column "name"; rr:datatype xsd:string ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:stock;
    rr:objectMap [ rr:column "stock"; rr:datatype xsd:integer ];
  ];
  rr:predicateObjectMap [
    rr:predicate ex:current_price;
    rr:objectMap [ rr:column "current_price"; rr:datatype xsd:decimal ];
  ].