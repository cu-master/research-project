@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://example.org/ontology/> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix map: <http://example.org/mapping/> .

map:ArtistsTriplesMap
  rr:logicalTable [ rr:tableName "artists" ];
  rr:subjectMap [
    rr:template "http://example.org/resource/artist/{constituent_id}";
    rr:class ex:Artist
  ];
  rr:predicateObjectMap [
    rr:predicate ex:name;
    rr:objectMap [ rr:column "name"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:biography;
    rr:objectMap [ rr:column "bio"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:nationality;
    rr:objectMap [ rr:column "nationality"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:gender;
    rr:objectMap [ rr:column "gender"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:birthYear;
    rr:objectMap [ rr:column "birth_year"; rr:datatype xsd:integer ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:deathYear;
    rr:objectMap [ rr:column "death_year"; rr:datatype xsd:integer ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:wikiQid;
    rr:objectMap [ rr:column "wiki_qid"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:ulanId;
    rr:objectMap [ rr:column "ulan_id"; rr:datatype xsd:string ]
  ] .

map:ArtworksTriplesMap
  rr:logicalTable [ rr:tableName "artworks" ];
  rr:subjectMap [
    rr:template "http://example.org/resource/artwork/{object_id}";
    rr:class ex:Artwork
  ];
  rr:predicateObjectMap [
    rr:predicate ex:title;
    rr:objectMap [ rr:column "title"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:artistName;
    rr:objectMap [ rr:column "artist"; rr:datatype xsd:string ] # Assumption: free-text artist name when no normalized FK exists
  ];
  rr:predicateObjectMap [
    rr:predicate ex:constituentIdentifier;
    rr:objectMap [ rr:column "constituent_id"; rr:datatype xsd:string ] # Assumption: stored as text; used as legacy artist identifier
  ];
  rr:predicateObjectMap [
    rr:predicate ex:artistBiography;
    rr:objectMap [ rr:column "artist_bio"; rr:datatype xsd:string ] # Assumption: denormalized artist biography
  ];
  rr:predicateObjectMap [
    rr:predicate ex:nationality;
    rr:objectMap [ rr:column "nationality"; rr:datatype xsd:string ] # Assumption: denormalized artist nationality
  ];
  rr:predicateObjectMap [
    rr:predicate ex:beginDate;
    rr:objectMap [ rr:column "begin_date"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:endDate;
    rr:objectMap [ rr:column "end_date"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:gender;
    rr:objectMap [ rr:column "gender"; rr:datatype xsd:string ] # Assumption: denormalized artist gender
  ];
  rr:predicateObjectMap [
    rr:predicate ex:creationDate;
    rr:objectMap [ rr:column "date"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:medium;
    rr:objectMap [ rr:column "medium"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:dimensions;
    rr:objectMap [ rr:column "dimensions"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:creditLine;
    rr:objectMap [ rr:column "credit_line"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:accessionNumber;
    rr:objectMap [ rr:column "accession_number"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:classification;
    rr:objectMap [ rr:column "classification"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:department;
    rr:objectMap [ rr:column "department"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:dateAcquired;
    rr:objectMap [ rr:column "date_acquired"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:cataloged;
    rr:objectMap [ rr:column "cataloged"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:objectId;
    rr:objectMap [ rr:column "object_id"; rr:datatype xsd:integer ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:url;
    rr:objectMap [ rr:column "url"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:imageUrl;
    rr:objectMap [ rr:column "image_url"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:onView;
    rr:objectMap [ rr:column "on_view"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:circumferenceCm;
    rr:objectMap [ rr:column "circumference_cm"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:depthCm;
    rr:objectMap [ rr:column "depth_cm"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:diameterCm;
    rr:objectMap [ rr:column "diameter_cm"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:heightCm;
    rr:objectMap [ rr:column "height_cm"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:lengthCm;
    rr:objectMap [ rr:column "length_cm"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:weightKg;
    rr:objectMap [ rr:column "weight_kg"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:widthCm;
    rr:objectMap [ rr:column "width_cm"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:seatHeightCm;
    rr:objectMap [ rr:column "seat_height_cm"; rr:datatype xsd:string ]
  ];
  rr:predicateObjectMap [
    rr:predicate ex:durationSeconds;
    rr:objectMap [ rr:column "duration_sec"; rr:datatype xsd:string ]
  ] .