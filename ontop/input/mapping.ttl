@prefix rr:  <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:  <http://semweb.mmlab.be/ns/ql#> .
@prefix ex:  <http://example.org/ontology/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@base <http://example.org/mapping/airlines/> .

<#AircraftTriplesMap>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:tableName "aircrafts_data" ;
  ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/aircraft/{aircraft_code}" ;
    rr:class ex:Aircraft ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:aircraftCode ;
    rr:objectMap [
      rr:column "aircraft_code" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:modelJson ;
    rr:objectMap [
      rr:column "model" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:rangeKm ;
    rr:objectMap [
      rr:column "range" ;
      rr:datatype xsd:integer ;
    ] ;
  ] .

<#AirportTriplesMap>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:tableName "airports_data" ;
  ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/airport/{airport_code}" ;
    rr:class ex:Airport ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:airportCode ;
    rr:objectMap [
      rr:column "airport_code" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:airportNameJson ;
    rr:objectMap [
      rr:column "airport_name" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:cityJson ;
    rr:objectMap [
      rr:column "city" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:coordinates ;
    rr:objectMap [
      rr:column "coordinates" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:timezone ;
    rr:objectMap [
      rr:column "timezone" ;
      rr:datatype xsd:string ;
    ] ;
  ] .

<#BookingTriplesMap>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:tableName "bookings" ;
  ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/booking/{book_ref}" ;
    rr:class ex:Booking ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:bookingReference ;
    rr:objectMap [
      rr:column "book_ref" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:bookingDateTime ;
    rr:objectMap [
      rr:column "book_date" ;
      rr:datatype xsd:dateTime ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:totalAmount ;
    rr:objectMap [
      rr:column "total_amount" ;
      rr:datatype xsd:decimal ;
    ] ;
  ] .

<#TicketTriplesMap>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:tableName "tickets" ;
  ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/ticket/{ticket_no}" ;
    rr:class ex:Ticket ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:ticketNumber ;
    rr:objectMap [
      rr:column "ticket_no" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:passengerId ;
    rr:objectMap [
      rr:column "passenger_id" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:passengerName ;
    rr:objectMap [
      rr:column "passenger_name" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:contactDataJson ;
    rr:objectMap [
      rr:column "contact_data" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:booking ;
    rr:objectMap [
      rr:parentTriplesMap <#BookingTriplesMap> ;
      rr:joinCondition [
        rr:child "book_ref" ;
        rr:parent "book_ref" ;
      ] ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:bookRef ;
    rr:objectMap [
      rr:column "book_ref" ;
      rr:datatype xsd:string ;
    ] ;
  ] .

<#FlightTriplesMap>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:tableName "flights" ;
  ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/flight/{flight_id}" ;
    rr:class ex:Flight ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:flightId ;
    rr:objectMap [
      rr:column "flight_id" ;
      rr:datatype xsd:integer ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:flightNumber ;
    rr:objectMap [
      rr:column "flight_no" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:scheduledDeparture ;
    rr:objectMap [
      rr:column "scheduled_departure" ;
      rr:datatype xsd:dateTime ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:scheduledArrival ;
    rr:objectMap [
      rr:column "scheduled_arrival" ;
      rr:datatype xsd:dateTime ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:status ;
    rr:objectMap [
      rr:column "status" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:actualDeparture ;
    rr:objectMap [
      rr:column "actual_departure" ;
      rr:datatype xsd:dateTime ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:actualArrival ;
    rr:objectMap [
      rr:column "actual_arrival" ;
      rr:datatype xsd:dateTime ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:departureAirport ;
    rr:objectMap [
      rr:parentTriplesMap <#AirportTriplesMap> ;
      rr:joinCondition [
        rr:child "departure_airport" ;
        rr:parent "airport_code" ;
      ] ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:arrivalAirport ;
    rr:objectMap [
      rr:parentTriplesMap <#AirportTriplesMap> ;
      rr:joinCondition [
        rr:child "arrival_airport" ;
        rr:parent "airport_code" ;
      ] ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:aircraft ;
    rr:objectMap [
      rr:parentTriplesMap <#AircraftTriplesMap> ;
      rr:joinCondition [
        rr:child "aircraft_code" ;
        rr:parent "aircraft_code" ;
      ] ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:departureAirportCode ;
    rr:objectMap [
      rr:column "departure_airport" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:arrivalAirportCode ;
    rr:objectMap [
      rr:column "arrival_airport" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:aircraftCode ;
    rr:objectMap [
      rr:column "aircraft_code" ;
      rr:datatype xsd:string ;
    ] ;
  ] .

<#SeatTriplesMap>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:tableName "seats" ;
  ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/seat/{aircraft_code}/{seat_no}" ;
    rr:class ex:Seat ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:seatNumber ;
    rr:objectMap [
      rr:column "seat_no" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:fareConditions ;
    rr:objectMap [
      rr:column "fare_conditions" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:aircraft ;
    rr:objectMap [
      rr:parentTriplesMap <#AircraftTriplesMap> ;
      rr:joinCondition [
        rr:child "aircraft_code" ;
        rr:parent "aircraft_code" ;
      ] ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:aircraftCode ;
    rr:objectMap [
      rr:column "aircraft_code" ;
      rr:datatype xsd:string ;
    ] ;
  ] .

<#TicketFlightTriplesMap>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:tableName "ticket_flights" ;
  ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/ticket-flight/{ticket_no}/{flight_id}" ;
    rr:class ex:TicketFlight ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:fareConditions ;
    rr:objectMap [
      rr:column "fare_conditions" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:amount ;
    rr:objectMap [
      rr:column "amount" ;
      rr:datatype xsd:decimal ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:ticket ;
    rr:objectMap [
      rr:parentTriplesMap <#TicketTriplesMap> ;
      rr:joinCondition [
        rr:child "ticket_no" ;
        rr:parent "ticket_no" ;
      ] ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:flight ;
    rr:objectMap [
      rr:parentTriplesMap <#FlightTriplesMap> ;
      rr:joinCondition [
        rr:child "flight_id" ;
        rr:parent "flight_id" ;
      ] ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:ticketNumber ;
    rr:objectMap [
      rr:column "ticket_no" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:flightId ;
    rr:objectMap [
      rr:column "flight_id" ;
      rr:datatype xsd:integer ;
    ] ;
  ] .

<#BoardingPassTriplesMap>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:tableName "boarding_passes" ;
  ] ;
  rr:subjectMap [
    rr:template "http://example.org/resource/boarding-pass/{ticket_no}/{flight_id}" ;
    rr:class ex:BoardingPass ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:boardingNumber ;
    rr:objectMap [
      rr:column "boarding_no" ;
      rr:datatype xsd:integer ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:seatNumber ;
    rr:objectMap [
      rr:column "seat_no" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:ticketFlight ;
    rr:objectMap [
      rr:parentTriplesMap <#TicketFlightTriplesMap> ;
      rr:joinCondition [
        rr:child "ticket_no" ;
        rr:parent "ticket_no" ;
      ] ;
      rr:joinCondition [
        rr:child "flight_id" ;
        rr:parent "flight_id" ;
      ] ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:ticketNumber ;
    rr:objectMap [
      rr:column "ticket_no" ;
      rr:datatype xsd:string ;
    ] ;
  ] ;
  rr:predicateObjectMap [
    rr:predicate ex:flightId ;
    rr:objectMap [
      rr:column "flight_id" ;
      rr:datatype xsd:integer ;
    ] ;
  ] .

# Assumptions / notes:
# - JSONB columns (aircrafts_data.model, airports_data.airport_name, airports_data.city, tickets.contact_data) are mapped as xsd:string literals (serialized JSON) via ex:*Json properties because no explicit ontology structure for multilingual/contact subfields was provided.
# - airports_data.coordinates (PostgreSQL point) is mapped as xsd:string via ex:coordinates because no explicit geo ontology/property was provided.
# - Some redundant code columns (e.g., flights.departure_airport, flights.arrival_airport, flights.aircraft_code, tickets.book_ref) are also mapped as literals alongside object properties for convenience/traceability.